{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": ["**"]
    },
    {
      "identifier": "fs:allow-write",
      "allow": ["**"]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": ["**"]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": ["**"]
    }
  ]
}